# ============================================================
# Variables d'environnement PRODUCTION pour Vercel
# Copier ces clés dans : Vercel > Project > Settings > Environment Variables
# ============================================================

# ── SUPABASE ──────────────────────────────────────────────
# Récupérer sur: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=VOTRE_SERVICE_ROLE_KEY (⚠️ NE JAMAIS exposer côté client)

# ── SITE ──────────────────────────────────────────────────
# IMPORTANT: Changer pour votre domaine production
NEXT_PUBLIC_SITE_URL=https://ecompilot.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@ecompilot.com
FREE_ACTION_LIMIT=50

# ── SHOPIFY ───────────────────────────────────────────────
# https://partners.shopify.com → App → API credentials
NEXT_PUBLIC_SHOPIFY_API_KEY=VOTRE_SHOPIFY_API_KEY
SHOPIFY_API_KEY=VOTRE_SHOPIFY_API_KEY
SHOPIFY_API_SECRET=VOTRE_SHOPIFY_API_SECRET
SHOPIFY_STORE_URL=https://VOTRE_BOUTIQUE.myshopify.com
SHOPIFY_PARTNER_EMAIL=VOTRE_EMAIL@domaine.com

# ── STRIPE PRODUCTION ─────────────────────────────────────
# IMPORTANT: Utiliser les clés LIVE (pas test) en production
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_LIVE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE_LIVE

# Webhook: https://dashboard.stripe.com/webhooks
# → Ajouter endpoint: https://ecompilot.com/api/stripe/webhook
# → Events: customer.subscription.created/updated/deleted, checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_WEBHOOK_SECRET_LIVE

# Price IDs LIVE: https://dashboard.stripe.com/products
# IMPORTANT: Recréer les produits en mode LIVE ou utiliser /api/stripe/setup en prod
STRIPE_STARTER_MONTHLY_PRICE_ID=price_LIVE_STARTER_MONTHLY
STRIPE_STARTER_YEARLY_PRICE_ID=price_LIVE_STARTER_YEARLY
STRIPE_PRO_MONTHLY_PRICE_ID=price_LIVE_PRO_MONTHLY
STRIPE_PRO_YEARLY_PRICE_ID=price_LIVE_PRO_YEARLY
STRIPE_SCALE_MONTHLY_PRICE_ID=price_LIVE_SCALE_MONTHLY
STRIPE_SCALE_YEARLY_PRICE_ID=price_LIVE_SCALE_YEARLY

STRIPE_PAYPAL_ENABLED=false

# ── OPENAI (si utilisé) ───────────────────────────────────
# OPENAI_API_KEY=sk-VOTRE_CLE_OPENAI

# ============================================================
# CHECKLIST DÉPLOIEMENT VERCEL:
# 1. Importer le repo GitHub Vegeta243/catalog-saas sur vercel.com
# 2. Ajouter TOUTES ces variables dans Settings > Environment Variables
# 3. Mettre NEXT_PUBLIC_SITE_URL = https://ecompilot.com
# 4. Déployer → récupérer l'URL Vercel temporaire
# 5. Ajouter le domaine ecompilot.com dans Settings > Domains
# 6. Configurer DNS chez registrar:
#    - A record: @ → 76.76.21.21 (IP Vercel)
#    - CNAME: www → cname.vercel-dns.com
# 7. Créer webhook Stripe LIVE pointant vers https://ecompilot.com/api/stripe/webhook
# 8. Visiter https://ecompilot.com/api/stripe/setup pour créer les Price IDs LIVE
# ============================================================
