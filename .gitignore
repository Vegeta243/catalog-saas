# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# test / scratch files (not part of the production build)
test-*.mjs
test-*.html
testShopifyConnection.js

# env files (secrets - ne pas committer)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.production.example est versionné (pas de secrets)

# vercel
.vercel
.env.vercel.tmp

# scripts with hardcoded credentials
scripts/add-google-redirect-uri*.mjs
scripts/check-google-session.mjs
scripts/extract_chrome_cookies*.py

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local

# Android keystore (NEVER commit - needed for Play Store updates)
keys/*.keystore
keys/*.jks
keys/*.p12
*.keystore
*.b64
android/app/ecompilot-release.keystore
android/app/keystore.b64
android/app/keystore-clean.b64
android/app/keystore-secret.txt

# Android build outputs
android/app/build/
android/.gradle/
android/build/
android/capacitor-cordova-android-plugins/build/
android/capacitor-android/build/
android/.idea/
android/local.properties